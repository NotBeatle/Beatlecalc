<?xml version="1.0" encoding="UTF-8" ?>
<widget id="com.notbeatle.calculator" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Beatle Calc</name>
    <description>A sleek, native-feeling utility application.</description>
    <author>Prathamesh Sathe</author>
    
    <content src="index.html" />
    
    <preference name="Orientation" value="portrait" />
    <preference name="FullScreen" value="true" />
    <preference name="BackgroundColor" value="ff000000" />
    <preference name="DisallowOverscroll" value="true" />
    
    <icon src="logo.svg" />
</widget>
